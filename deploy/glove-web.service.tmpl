# Template for /etc/systemd/system/glove-web.service.
#
# This file is NOT installed verbatim: `make install` substitutes the
# @PLACEHOLDER@ values (repo path, mise Ruby path, service user) and writes
# the result to /etc/systemd/system. Never edit the installed unit by hand —
# change this template and re-run `make install-web`.

[Unit]
Description=Glove (Puma + Solid Queue)
After=network.target
Wants=network.target

[Service]
Type=simple
User=@SERVICE_USER@
Group=@SERVICE_USER@
WorkingDirectory=@APP_DIR@
ExecStart=@APP_DIR@/bin/thrust @APP_DIR@/bin/rails server -e production
ExecReload=/bin/kill -USR1 $MAINPID
Restart=on-failure
RestartSec=5
SyslogIdentifier=glove-web

# Environment
Environment=PATH=@RUBY_DIR@/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
Environment=RAILS_ENV=production
# Puma listens on PORT, loopback only (config/puma.rb binds HOST). Thruster
# listens on HTTP_PORT on all interfaces; the reverse proxy on the Caddy
# machine connects to it over Tailscale. Ports 3001/3002 belong to notes.
Environment=HOST=127.0.0.1
Environment=PORT=3003
Environment=TARGET_PORT=3003
Environment=HTTP_PORT=3004
Environment=SOLID_QUEUE_IN_PUMA=true
Environment=RAILS_LOG_LEVEL=info
Environment=PIDFILE=@APP_DIR@/tmp/pids/server.pid
Environment=RUBY_YJIT_ENABLE=1
# All runtime settings and secrets (RAILS_RELATIVE_URL_ROOT,
# RAILS_PRODUCTION_HOSTS, Google OAuth, optional RAILS_MASTER_KEY) live in
# the repo so they migrate with it.
EnvironmentFile=-@APP_DIR@/.env

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=false
ReadWritePaths=@APP_DIR@/storage
ReadWritePaths=@APP_DIR@/log
ReadWritePaths=@APP_DIR@/tmp

# Resource limits
LimitNOFILE=65536
TimeoutStartSec=30
TimeoutStopSec=30
KillMode=mixed
KillSignal=SIGTERM

[Install]
WantedBy=multi-user.target
