# Copy to deploy/backup.env (gitignored) and fill in real values.
# Loaded by glove-backup.service; keep permissions tight: chmod 600.
S3_BUCKET=my-glove-backup-bucket
S3_PREFIX=glove
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1

# Optional: push a notification after each backup (success or failure).
#NTFY_TOPIC=my-topic
#NTFY_URL=https://ntfy.sh
